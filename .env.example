# ===========================
# DATABASE
# ===========================
# Desenvolvimento local (Docker):
DATABASE_URL="postgresql://casalperfeito:casalperfeito_secret@localhost:5432/casalperfeito"
DIRECT_URL="postgresql://casalperfeito:casalperfeito_secret@localhost:5432/casalperfeito"

# Produção (Supabase) — use Session Pooler (porta 5432) para compatibilidade IPv4:
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.dlxshfozxwzupcuyjibg.supabase.co:5432/postgres"

# ===========================
# JWT
# ===========================
JWT_SECRET="change_this_in_production"
JWT_EXPIRES_IN="7d"

# ===========================
# APP
# ===========================
PORT=3000
NODE_ENV=production
CORS_ORIGIN="https://your-frontend-domain.vercel.app"

# ===========================
# MERCADO PAGO
# ===========================
MP_ACCESS_TOKEN="your-production-access-token"
MP_WEBHOOK_SECRET="your-webhook-secret"

# ===========================
# PREÇO DO SITE
# ===========================
SITE_PRICE_BRL=50.00
